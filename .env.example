# ===================================
# FIREBASE CONFIGURATION (PRODUCTION)
# ===================================
# Obtenha esses valores em:
# Firebase Console > Configurações do Projeto > Seus apps > Web app
# https://console.firebase.google.com/

VITE_FIREBASE_API_KEY="sua_api_key_aqui"
VITE_FIREBASE_AUTH_DOMAIN="seu-projeto.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="seu-projeto-id"
VITE_FIREBASE_STORAGE_BUCKET="seu-projeto.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="000000000000"
VITE_FIREBASE_APP_ID="1:000000000000:web:SEU_APP_ID_WEB"
VITE_FIREBASE_MEASUREMENT_ID="G-XXXXXXXXXX"

# ===================================
# STRIPE CONFIGURATION
# ===================================
# Obtenha em: https://dashboard.stripe.com/apikeys
# Use pk_test_ em desenvolvimento e pk_live_ em produção
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ===================================
# ANDROID BUILD
# ===================================
# Senha do keystore de assinatura (NUNCA commite o valor real!)
# Configure como variável de ambiente no CI/CD ou localmente:
# export HORAMED_KEYSTORE_PASSWORD="sua_senha_do_keystore"
