# ===================================
# FIREBASE CONFIGURATION (PRODUCTION)
# ===================================
# Obtenha esses valores em:
# Firebase Console > Configurações do Projeto > Seus apps > Web app
# https://console.firebase.google.com/project/horamed-firebase/settings/general

VITE_FIREBASE_API_KEY="sua_api_key_aqui"
VITE_FIREBASE_AUTH_DOMAIN="horamed-firebase.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="horamed-firebase"
VITE_FIREBASE_STORAGE_BUCKET="horamed-firebase.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="299174581868"
VITE_FIREBASE_APP_ID="1:299174581868:web:SEU_APP_ID_WEB"
VITE_FIREBASE_MEASUREMENT_ID="G-XXXXXXXXXX"

# ===================================
# STRIPE CONFIGURATION (opcional)
# ===================================
# Obtenha em: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY="pk_live_..."

# ===================================
# ANDROID BUILD
# ===================================
# Senha do keystore de assinatura (NUNCA commite o valor real!)
# Configure como variável de ambiente no CI/CD ou localmente:
# export HORAMED_KEYSTORE_PASSWORD="sua_senha_do_keystore"
