rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===================================
    // Helper Functions
    // ===================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    // Verifica se o usuário logado é cuidador APROVADO do paciente
    function isCaregiverOf(userId) {
      return isAuthenticated() &&
        exists(/databases//documents/users//caregivers/) &&
        get(/databases//documents/users//caregivers/).data.status == "approved";
    }

    // Campos que um cuidador pode alterar numa dose
    function caregiverDoseFields() {
      return ['status', 'takenAt', 'skippedAt', 'missedAt', 'updatedAt', 'dueAt'];
    }

    // Campos que um cuidador pode alterar no registro de cuidado
    function caregiverSelfFields() {
      return ['status', 'updatedAt', 'acceptedAt', 'respondedAt'];
    }


    // ===================================
    // Users Collection
    // ===================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isCaregiverOf(userId);
      allow write: if isOwner(userId);

      // Perfis Familiares (legado)
      match /familyProfiles/{profileId} {
        allow read, write: if isOwner(userId);
      }

      // Perfis (nova estrutura)
      match /profiles/{profileId} {
        allow read, write: if isOwner(userId);

        // Doses aninhadas por perfil
        match /doses/{doseId} {
          allow read: if isOwner(userId) || isCaregiverOf(userId);
          allow create, delete: if isOwner(userId);
          allow update: if isOwner(userId) ||
            (isCaregiverOf(userId) &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly(caregiverDoseFields()));
        }

        // Eventos de saúde por perfil
        match /healthEvents/{eventId} {
          allow read: if isOwner(userId) || isCaregiverOf(userId);
          allow write: if isOwner(userId);
        }
      }

      // Medicamentos
      match /medications/{medicationId} {
        allow read: if isOwner(userId) || isCaregiverOf(userId);
        allow write: if isOwner(userId);
      }

      // Doses (raiz do usuário, sem perfil)
      match /doses/{doseId} {
        allow read: if isOwner(userId) || isCaregiverOf(userId);
        allow create, delete: if isOwner(userId);
        allow update: if isOwner(userId) ||
          (isCaregiverOf(userId) &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(caregiverDoseFields()));
      }


      // Agendamentos (schedules)
      match /schedules/{scheduleId} {
        allow read: if isOwner(userId) || isCaregiverOf(userId);
        allow write: if isOwner(userId);
      }

      // Estoque
      match /stock/{stockId} {
        allow read: if isOwner(userId) || isCaregiverOf(userId);
        allow write: if isOwner(userId);
      }

      // Documentos médicos
      match /documents/{documentId} {
        allow read, write: if isOwner(userId);
      }

      // Health Documents (nova estrutura)
      match /healthDocuments/{documentId} {
        allow read, write: if isOwner(userId);
      }

      // Relatórios
      match /reports/{reportId} {
        allow read, write: if isOwner(userId);
      }

      // Histórico de peso
      match /weightHistory/{entryId} {
        allow read, write: if isOwner(userId);
      }

      // Vacinações
      match /vaccinations/{vaccinationId} {
        allow read: if isOwner(userId) || isCaregiverOf(userId);
        allow write: if isOwner(userId);
      }

      // Transações de XP
      match /xpTransactions/{transactionId} {
        allow read, write: if isOwner(userId);
      }

      // Conquistas
      match /achievements/{achievementId} {
        allow read, write: if isOwner(userId);
      }


      // Indicações/Referrals
      match /referrals/{referralId} {
        allow read, write: if isOwner(userId);
      }

      // Assinatura — LEITURA apenas para clientes
      // Escrita exclusiva via Admin SDK (Cloud Functions)
      match /subscription/{subscriptionId} {
        allow read: if isOwner(userId);
      }

      // Push Subscriptions
      match /pushSubscriptions/{subscriptionId} {
        allow read, write: if isOwner(userId);
      }

      // Métricas de notificação
      match /notificationMetrics/{metricId} {
        allow read, write: if isOwner(userId);
      }

      // Métricas do app — CORRIGIDO: permite update além de create
      match /appMetrics/{metricId} {
        allow read, create, update: if isOwner(userId);
      }

      // Recompensas de indicação — somente leitura
      match /referralRewards/{rewardId} {
        allow read: if isOwner(userId);
      }

      // Recompensas — somente leitura
      match /rewards/{rewardId} {
        allow read: if isOwner(userId);
      }

      // Prestadores de saúde
      match /providers/{providerId} {
        allow read, write: if isOwner(userId);
      }


      // Cuidadores — CORRIGIDO: cuidador pode aceitar/recusar apenas seu próprio status
      match /caregivers/{caregiverUid} {
        allow read: if isOwner(userId) || request.auth.uid == caregiverUid;
        // Dono gerencia quem é cuidador
        allow create, delete: if isOwner(userId);
        // Dono pode alterar tudo; cuidador só atualiza seu próprio status
        allow update: if isOwner(userId) ||
          (request.auth.uid == caregiverUid &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(caregiverSelfFields()));
      }

      // Notificações locais
      match /notifications/{notificationId} {
        allow read, write: if isOwner(userId);
      }

      // Diário de efeitos colaterais
      match /sideEffects/{entryId} {
        allow read, write: if isOwner(userId);
      }

      // Eventos de saúde (raiz do usuário)
      match /healthEvents/{eventId} {
        allow read: if isOwner(userId) || isCaregiverOf(userId);
        allow write: if isOwner(userId);
      }

      // Consentimentos LGPD/GDPR
      match /consents/{consentId} {
        allow read, write: if isOwner(userId);
      }

      // Alarmes
      match /alarms/{alarmId} {
        allow read, write: if isOwner(userId);
      }

      // Logs de auditoria — append-only para clientes
      match /auditLogs/{logId} {
        allow read, create: if isOwner(userId);
      }
    }


    // ===================================
    // dose_instances — Coleção top-level
    // Usada pelo MedicationRepository para gerenciamento cross-profile
    // CRÍTICO: estava sem regras — qualquer usuário podia ler/escrever!
    // ===================================
    match /dose_instances/{doseId} {
      // Leitura: dono ou cuidador aprovado
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isCaregiverOf(resource.data.userId)
      );

      // Criação: só o dono, e o campo userId deve bater com quem está criando
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;

      // Atualização: dono pode tudo; cuidador só altera campos de status de dose
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        (isCaregiverOf(resource.data.userId) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(caregiverDoseFields()))
      );

      // Exclusão: apenas o dono
      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    // ===================================
    // Campanhas & Marketing
    // ===================================
    match /campaigns/{campaignId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===================================
    // Documentos Compartilhados (tempo limitado)
    // ===================================
    match /sharedDocuments/{shareId} {
      allow read: if resource.data.expiresAt > request.time;
      allow create: if isAuthenticated() &&
        request.resource.data.ownerId == request.auth.uid &&
        request.resource.data.expiresAt is timestamp &&
        request.resource.data.expiresAt > request.time;
      allow delete: if isAuthenticated() &&
        resource.data.ownerId == request.auth.uid;
    }

    // ===================================
    // Dados Globais de Referência (somente leitura para clientes)
    // ===================================

    // Interações medicamentosas
    match /interactions/{interactionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Feature Flags
    match /featureFlags/{flagId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Configurações do app
    match /appConfig/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ===================================
    // Top-Level Collections — SECURITY FIX
    // Coleções sem regras estavam abertas para qualquer usuário autenticado
    // ===================================

    // Symptom logs (dados de saúde sensíveis — LGPD)
    match /symptom_logs/{logId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Items (medicamentos — legado/migração)
    match /items/{itemId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Subscriptions (dados de pagamento)
    match /subscriptions/{subId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow write: if isAdmin();
    }

    // Notification preferences
    match /notification_preferences/{prefId} {
      allow read, write: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
    }

    // User profiles (legado/migração)
    match /user_profiles/{profileId} {
      allow read, write: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
    }

    // Health insights
    match /health_insights/{insightId} {
      allow read, write: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
    }

    // Health history
    match /health_history/{entryId} {
      allow read, write: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
    }

    // Medical exams
    match /medical_exams/{examId} {
      allow read, write: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
    }

    // Document sharing (legado)
    match /compartilhamentos_doc/{shareId} {
      allow read, write: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
    }

    // Health events (legado)
    match /eventos_saude/{eventId} {
      allow read, write: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
    }

    // Health documents (legado)
    match /documentos_saude/{docId} {
      allow read, write: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
    }

    // Profiles (legado)
    match /profiles/{profileId} {
      allow read, write: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
    }

    // Schedules (top-level — legado)
    match /schedules/{scheduleId} {
      allow read, write: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Stock (top-level — legado)
    match /stock/{stockId} {
      allow read, write: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
  }
}

